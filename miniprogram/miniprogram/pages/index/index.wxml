<view class="container">
  <!-- Hero Section -->
  <view class="hero-section">
    <view class="hero-title">一键生成创意内容</view>
    <view class="hero-subtitle">输入你的灵感，让 AI 为你生成图片、文案和视频</view>
  </view>

  <!-- Quota Cards -->
  <view class="quota-section" wx:if="{{quota}}">
    <view class="quota-card">
      <view class="quota-num" style="color: #6366f1;">{{quota.remainingImages}}</view>
      <view class="quota-label">图片次数</view>
    </view>
    <view class="quota-card">
      <view class="quota-num" style="color: #10b981;">{{quota.remainingTexts}}</view>
      <view class="quota-label">文案次数</view>
    </view>
    <view class="quota-card">
      <view class="quota-num" style="color: #8b5cf6;">{{quota.remainingFreeEdits}}</view>
      <view class="quota-label">视频次数</view>
    </view>
  </view>

  <!-- User Section -->
  <view class="user-section" wx:if="{{!isLoggedIn}}">
    <view class="login-tip">登录后享受更多创作次数</view>
    <view class="login-btns">
      <button class="btn-login" bindtap="goToLogin">登录</button>
      <button class="btn-register" bindtap="goToRegister">注册</button>
    </view>
  </view>

  <!-- Input Section -->
  <view class="input-section card">
    <view class="section-title">开始创作</view>
    
    <textarea 
      class="prompt-input" 
      placeholder="描述你的创作灵感，例如：一只可爱的橘猫在阳光下打盹..."
      value="{{prompt}}"
      bindinput="onPromptInput"
      maxlength="500"
    />
    
    <!-- 时长选择 -->
    <view class="duration-section">
      <view class="duration-title">视频时长</view>
      <radio-group bindchange="onDurationChange">
        <view class="duration-options">
          <label class="duration-item">
            <radio value="0" checked="{{durationType === 'free'}}" />
            <text>5秒（免费）</text>
          </label>
          <label class="duration-item">
            <radio value="1" />
            <text>10秒</text>
          </label>
          <label class="duration-item">
            <radio value="2" />
            <text>15秒</text>
          </label>
          <label class="duration-item">
            <radio value="3" />
            <text>20秒</text>
          </label>
        </view>
      </radio-group>
    </view>

    <!-- 生成按钮 -->
    <view class="action-btns">
      <button class="btn-primary btn-block" bindtap="handleGenerateAll" disabled="{{loading}}">
        {{loading ? '生成中...' : '一键生成全部'}}
      </button>
    </view>

    <!-- 单独生成按钮 -->
    <view class="separate-btns">
      <button class="btn-secondary" bindtap="handleGenerateImages" disabled="{{loading}}">生成图片</button>
      <button class="btn-secondary" bindtap="handleGenerateTexts" disabled="{{loading}}">生成文案</button>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-section" wx:if="{{loading}}">
    <view class="loading-icon">⏳</view>
    <view class="loading-text">AI 正在创作中，请稍候...</view>
  </view>

  <!-- Results -->
  <view class="result-section" wx:if="{{result}}">
    <!-- 优化提示 -->
    <view class="optimization-note" wx:if="{{result.optimizationNote}}">
      <text>{{result.optimizationNote}}</text>
    </view>

    <!-- 生成图片 -->
    <view class="result-images" wx:if="{{result.imageUrls && result.imageUrls.length > 0}}">
      <view class="result-title">生成的图片</view>
      <view class="images-grid">
        <view class="image-item" wx:for="{{result.imageUrls}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
          <view class="image-actions">
            <button class="btn-action" bindtap="previewImage" data-url="{{item}}">预览</button>
            <button class="btn-action" bindtap="saveImage" data-url="{{item}}">保存</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 生成的文案 -->
    <view class="result-texts" wx:if="{{result.texts && result.texts.length > 0}}">
      <view class="result-title">生成的文案</view>
      <view class="text-list">
        <view class="text-item" wx:for="{{result.texts}}" wx:key="index">
          <text>{{item}}</text>
          <button class="btn-copy" bindtap="copyText" data-text="{{item}}">复制</button>
        </view>
      </view>
    </view>

    <!-- 生成的视频 -->
    <view class="result-video" wx:if="{{result.videoUrl}}">
      <view class="result-title">生成的视频</view>
      <video src="{{result.videoUrl}}" controls show-center-play-btn />
    </view>
  </view>

  <!-- Features -->
  <view class="features-section">
    <view class="feature-item">
      <view class="feature-icon">🖼️</view>
      <view class="feature-title">AI 图片生成</view>
      <view class="feature-desc">输入描述，快速生成精美图片</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">✍️</view>
      <view class="feature-title">智能文案</view>
      <view class="feature-desc">AI 帮你撰写优质文案内容</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">🎬</view>
      <view class="feature-title">视频生成</view>
      <view class="feature-desc">一键生成动态视频内容</view>
    </view>
  </view>
</view>
