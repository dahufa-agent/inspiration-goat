<view class="container">
  <!-- 未登录 -->
  <view class="not-login" wx:if="{{!isLoggedIn}}">
    <view class="avatar default">👤</view>
    <view class="login-tip">登录后查看更多信息</view>
    <button class="btn-login" bindtap="goToLogin">登录 / 注册</button>
  </view>

  <!-- 已登录 -->
  <view class="profile-section" wx:if="{{isLoggedIn}}">
    <!-- 用户信息 -->
    <view class="user-card">
      <view class="avatar">{{userInfo.username.charAt(0).toUpperCase()}}</view>
      <view class="user-info">
        <view class="username">{{userInfo.username}}</view>
        <view class="userphone">{{userInfo.phone}}</view>
      </view>
      <view class="vip-badge" wx:if="{{membership && membership.isVip}}">
        {{membership.isPermanentVip ? '永久' : '会员'}}
      </view>
    </view>

    <!-- 会员状态 -->
    <view class="membership-card" wx:if="{{membership}}">
      <view class="membership-icon">👑</view>
      <view class="membership-info">
        <view class="membership-title">
          {{membership.isPermanentVip ? '永久会员' : membership.isVip ? '会员' : '普通用户'}}
        </view>
        <view class="membership-desc" wx:if="{{membership.isVip && !membership.isPermanentVip}}">
          有效期至：{{membership.vipEndDate}}
        </view>
        <view class="membership-desc" wx:if="{{membership.isPermanentVip}}">
          终身有效
        </view>
      </view>
      <view class="membership-action" wx:if="{{!membership.isVip}}">
        <button class="btn-upgrade" bindtap="goToPage" data-url="/pages/membership/membership">
          升级
        </button>
      </view>
    </view>

    <!-- 每日签到 -->
    <view class="checkin-card">
      <view class="checkin-info">
        <view class="checkin-icon">🎁</view>
        <view class="checkin-text">
          <view class="checkin-title">每日签到</view>
          <view class="checkin-desc">签到即可获得10积分</view>
        </view>
      </view>
      <button class="btn-checkin" bindtap="handleCheckin">签到</button>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="goToPage" data-url="/pages/membership/membership">
        <view class="menu-icon">👑</view>
        <view class="menu-text">会员中心</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="goToPage" data-url="/pages/credits/credits">
        <view class="menu-icon">💰</view>
        <view class="menu-text">我的积分</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="handleActivateCode">
        <view class="menu-icon">🎫</view>
        <view class="menu-text">激活免费码</view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="goToPage" data-url="/pages/history/history">
        <view class="menu-icon">📜</view>
        <view class="menu-text">历史记录</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <!-- 退出登录 -->
    <button class="btn-logout" bindtap="handleLogout">退出登录</button>
  </view>
</view>
