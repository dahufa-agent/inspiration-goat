/* pages/register/register.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3f4f6 0%, #ffffff 100%);
  padding: 80rpx 48rpx 48rpx;
}

.register-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #6b7280;
}

.register-form {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  padding: 28rpx 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #6366f1;
  outline: none;
}

.code-input-row {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.btn-code {
  padding: 0 24rpx;
  background: #f3f4f6;
  color: #374151;
  border: none;
  border-radius: 12rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.btn-code[disabled] {
  color: #9ca3af;
}

.btn-register {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 24rpx;
}

.btn-register[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.login-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.login-link text {
  color: #6366f1;
  font-weight: 500;
}
