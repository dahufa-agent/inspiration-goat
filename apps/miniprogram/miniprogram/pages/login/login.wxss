/* pages/login/login.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3f4f6 0%, #ffffff 100%);
  padding: 120rpx 48rpx 48rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
}

.login-form {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  padding: 28rpx 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: #6366f1;
  outline: none;
}

.btn-login {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 24rpx;
}

.btn-login[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.register-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.register-link text {
  color: #6366f1;
  font-weight: 500;
}
