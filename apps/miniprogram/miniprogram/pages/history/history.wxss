/* pages/history/history.wxss */

.container {
  min-height: 100vh;
  background: #f3f4f6;
  padding-bottom: 120rpx;
}

/* Login Tip */
.login-tip {
  text-align: center;
  padding: 120rpx 48rpx;
}

.tip-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #6b7280;
  margin-bottom: 32rpx;
}

.btn-login {
  padding: 20rpx 64rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  font-size: 28rpx;
}

/* History List */
.history-list {
  padding: 24rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.item-type {
  font-size: 20rpx;
  background: #f3f4f6;
  color: #6b7280;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.item-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.item-images {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.item-images image {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
}

.item-text {
  background: #f9fafb;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
}
