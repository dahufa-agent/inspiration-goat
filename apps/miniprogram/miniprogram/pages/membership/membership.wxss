/* pages/membership/membership.wxss */

.container {
  min-height: 100vh;
  background: #f3f4f6;
  padding-bottom: 120rpx;
}

/* Status Card */
.status-card {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  color: #ffffff;
}

.status-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-icon {
  font-size: 64rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: 600;
}

.status-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.status-tip {
  margin-top: 20rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

/* Plans Section */
.plans-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.plans-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.plan-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  position: relative;
  border: 2rpx solid #e5e7eb;
}

.plan-card.popular {
  border-color: #6366f1;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.2);
}

.popular-tag {
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.plan-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.plan-period {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.plan-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.plan-features {
  text-align: left;
  margin-bottom: 20rpx;
}

.feature-item {
  font-size: 20rpx;
  color: #6b7280;
  padding: 6rpx 0;
  padding-left: 8rpx;
}

.feature-item::before {
  content: '✓';
  color: #10b981;
  margin-right: 8rpx;
}

.btn-plan {
  width: 100%;
  padding: 16rpx;
  background: #f3f4f6;
  color: #374151;
  border: none;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.btn-plan.primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
}

/* Permanent Section */
.permanent-section {
  margin: 32rpx 24rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 20rpx;
  padding: 32rpx;
}

.permanent-card {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.permanent-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.permanent-info {
  flex: 1;
}

.permanent-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #92400e;
}

.permanent-desc {
  font-size: 24rpx;
  color: #a16207;
  margin-top: 4rpx;
}

.permanent-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #92400e;
}

.btn-permanent {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
}
