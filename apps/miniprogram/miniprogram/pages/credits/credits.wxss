/* pages/credits/credits.wxss */

.container {
  min-height: 100vh;
  background: #f3f4f6;
  padding-bottom: 120rpx;
}

/* Balance Card */
.balance-card {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  margin: 24rpx;
  padding: 48rpx 32rpx;
  border-radius: 24rpx;
  color: #ffffff;
  text-align: center;
}

.balance-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.balance-num {
  font-size: 80rpx;
  font-weight: 700;
  margin: 16rpx 0 24rpx;
}

.btn-recharge {
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #ffffff;
  color: #6366f1;
  border: none;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* Pricing Section */
.pricing-section {
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.pricing-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 2rpx solid #e5e7eb;
}

.pricing-item.highlight {
  background: #eef2ff;
  border-color: #6366f1;
}

.pricing-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.pricing-label {
  font-size: 20rpx;
  color: #6b7280;
  margin: 4rpx 0;
}

.pricing-price {
  font-size: 24rpx;
  font-weight: 600;
  color: #6366f1;
}

.pricing-tag {
  font-size: 18rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

/* Rules Section */
.rules-section {
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.rules-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  width: 180rpx;
}

.rule-desc {
  flex: 1;
  font-size: 24rpx;
  color: #6b7280;
}

.rule-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #6366f1;
}

/* Records Section */
.records-section {
  padding: 0 24rpx;
}

.records-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-desc {
  font-size: 28rpx;
  color: #111827;
}

.record-time {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.record-amount.positive {
  color: #10b981;
}

.record-amount.negative {
  color: #ef4444;
}

/* Empty State */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}
