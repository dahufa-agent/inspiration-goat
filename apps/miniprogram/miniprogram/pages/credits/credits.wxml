<view class="container">
  <!-- 积分余额卡片 -->
  <view class="balance-card">
    <view class="balance-label">当前积分余额</view>
    <view class="balance-num">{{points}}</view>
    <button class="btn-recharge" bindtap="handleRecharge">充值积分</button>
  </view>

  <!-- 积分定价 -->
  <view class="pricing-section">
    <view class="section-title">积分定价</view>
    <view class="pricing-grid">
      <view class="pricing-item">
        <view class="pricing-num">10</view>
        <view class="pricing-label">积分</view>
        <view class="pricing-price">¥1</view>
      </view>
      <view class="pricing-item">
        <view class="pricing-num">100</view>
        <view class="pricing-label">积分</view>
        <view class="pricing-price">¥9</view>
      </view>
      <view class="pricing-item">
        <view class="pricing-num">500</view>
        <view class="pricing-label">积分</view>
        <view class="pricing-price">¥39</view>
      </view>
      <view class="pricing-item highlight">
        <view class="pricing-num">1000</view>
        <view class="pricing-label">积分</view>
        <view class="pricing-price">¥69</view>
        <view class="pricing-tag">赠送15%</view>
      </view>
    </view>
  </view>

  <!-- 积分消耗规则 -->
  <view class="rules-section">
    <view class="section-title">积分消耗规则</view>
    <view class="rules-list">
      <view class="rule-item">
        <view class="rule-name">图片生成</view>
        <view class="rule-desc">超出免费次数后</view>
        <view class="rule-price">1积分/张</view>
      </view>
      <view class="rule-item">
        <view class="rule-name">文案生成</view>
        <view class="rule-desc">超出免费次数后</view>
        <view class="rule-price">2积分/条</view>
      </view>
      <view class="rule-item">
        <view class="rule-name">视频生成</view>
        <view class="rule-desc">基础5秒，超出按5秒计</view>
        <view class="rule-price">10积分/5秒</view>
      </view>
    </view>
  </view>

  <!-- 积分记录 -->
  <view class="records-section">
    <view class="section-title">积分记录</view>
    <view class="records-list" wx:if="{{transactions.length > 0}}">
      <view class="record-item" wx:for="{{transactions}}" wx:key="id">
        <view class="record-info">
          <view class="record-desc">{{item.description}}</view>
          <view class="record-time">{{item.created_at}}</view>
        </view>
        <view class="record-amount {{item.type === 'earn' ? 'positive' : 'negative'}}">
          {{item.type === 'earn' ? '+' : '-'}}{{item.amount}}
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <view class="empty-icon">📝</view>
      <view class="empty-text">暂无积分记录</view>
    </view>
  </view>
</view>
