/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3f4f6 0%, #ffffff 100%);
  padding-bottom: 120rpx;
}

/* Hero Section */
.hero-section {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 48rpx 32rpx;
  text-align: center;
  color: #ffffff;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* Quota Section */
.quota-section {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  margin: -40rpx 24rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.quota-card {
  text-align: center;
}

.quota-num {
  font-size: 44rpx;
  font-weight: 700;
}

.quota-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* User Section */
.user-section {
  padding: 32rpx;
  text-align: center;
}

.login-tip {
  color: #6b7280;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.login-btns {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.btn-login {
  padding: 20rpx 48rpx;
  border: 2rpx solid #6366f1;
  color: #6366f1;
  background: transparent;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.btn-register {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  font-size: 28rpx;
}

/* Input Section */
.input-section {
  margin: 24rpx;
  padding: 32rpx;
}

.prompt-input {
  width: 100%;
  height: 200rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

/* Duration Section */
.duration-section {
  margin-bottom: 24rpx;
}

.duration-title {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 16rpx;
}

.duration-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.duration-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f3f4f6;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* Action Buttons */
.action-btns {
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.separate-btns {
  display: flex;
  gap: 24rpx;
}

.btn-secondary {
  flex: 1;
  padding: 20rpx;
  background: #f3f4f6;
  color: #374151;
  border: none;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.btn-secondary[disabled] {
  opacity: 0.5;
}

/* Loading Section */
.loading-section {
  text-align: center;
  padding: 80rpx 32rpx;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.loading-text {
  color: #6b7280;
  font-size: 28rpx;
}

/* Result Section */
.result-section {
  padding: 0 24rpx;
}

.optimization-note {
  background: #fef3c7;
  color: #92400e;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.image-item {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 320rpx;
}

.image-actions {
  display: flex;
  justify-content: space-around;
  padding: 12rpx;
  background: rgba(0, 0, 0, 0.6);
}

.btn-action {
  font-size: 22rpx;
  color: #ffffff;
  background: transparent;
  padding: 8rpx 16rpx;
}

.text-list {
  margin-bottom: 32rpx;
}

.text-item {
  background: #ffffff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.text-item text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

.btn-copy {
  font-size: 22rpx;
  color: #6366f1;
  background: transparent;
  padding: 8rpx 16rpx;
  margin-left: 16rpx;
}

.result-video {
  margin-bottom: 32rpx;
}

.result-video video {
  width: 100%;
  border-radius: 12rpx;
}

/* Features Section */
.features-section {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 32rpx 24rpx;
}

.feature-item {
  text-align: center;
  padding: 24rpx 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: #6b7280;
}
